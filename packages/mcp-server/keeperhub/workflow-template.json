{
  "name": "AgentPassports Execute ENS-Verified Task",
  "description": "AgentPassports direct ENS KeeperHub gate. KeeperHub reads the Passport/Visa state from ENS first, routes failures to blocked stamps, and only then reaches execution. Payload contains no secrets.",
  "gateMode": "direct-ens-first",
  "capabilityStatus": {
    "directEnsReads": "template-not-live-import-proven",
    "conditionBranches": "template-not-live-import-proven",
    "blockedStampRouting": "template-not-live-import-proven",
    "agentEnsExecuteWrite": "previous-live-proof-web3-write-supported"
  },
  "inputs": {
    "chainId": "{{CHAIN_ID}}",
    "rpcUrl": "{{RPC_URL}}",
    "ensRegistryAddress": "{{ENS_REGISTRY}}",
    "executorAddress": "{{EXECUTOR_ADDRESS}}",
    "taskLogAddress": "{{TASK_LOG_ADDRESS}}",
    "requiredTextRecords": [
      "agent_status",
      "agent_policy_digest",
      "agent_policy_target",
      "agent_policy_selector",
      "agent_policy_max_value_wei",
      "agent_policy_max_gas_reimbursement_wei",
      "agent_policy_expires_at",
      "agent_policy_uniswap_enabled",
      "agent_policy_uniswap_chain_id",
      "agent_policy_uniswap_allowed_token_in",
      "agent_policy_uniswap_allowed_token_out",
      "agent_policy_uniswap_max_input_amount",
      "agent_policy_uniswap_max_slippage_bps",
      "agent_policy_uniswap_deadline_seconds",
      "agent_policy_uniswap_recipient",
      "agent_policy_uniswap_router",
      "agent_policy_uniswap_selector"
    ]
  },
  "nodes": [
    {
      "id": "agentpassports_trigger",
      "type": "trigger",
      "position": {
        "x": 0,
        "y": 0
      },
      "data": {
        "type": "trigger",
        "label": "AgentPassports action request",
        "config": {
          "triggerType": "Manual"
        },
        "status": "idle",
        "description": "Receives the agent action request. All subsequent KeeperHub nodes must pass before execution."
      }
    },
    {
      "id": "ens_resolve_passport",
      "type": "http-json-rpc",
      "position": {
        "x": 320,
        "y": 0
      },
      "capabilityStatus": "template-not-live-import-proven",
      "data": {
        "label": "Direct ENS Passport/Visa reads",
        "method": "POST",
        "url": "{{RPC_URL}}",
        "description": "KeeperHub direct ENS read node. It performs eth_call reads against the registry/resolver so KeeperHub, not the AgentPassports API, observes live Passport and Visa state.",
        "config": {
          "jsonrpc": "2.0",
          "calls": [
            {
              "purpose": "Passport resolver lookup",
              "to": "{{ENS_REGISTRY}}",
              "function": "resolver(bytes32)",
              "params": [
                "{{input.agentNode}}"
              ]
            },
            {
              "purpose": "Passport signer exists",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "addr(bytes32)",
              "params": [
                "{{input.agentNode}}"
              ]
            },
            {
              "purpose": "Visa text record agent_status",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_status"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_digest",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_digest"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_target",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_target"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_selector",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_selector"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_max_value_wei",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_max_value_wei"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_max_gas_reimbursement_wei",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_max_gas_reimbursement_wei"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_expires_at",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_expires_at"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_enabled",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_enabled"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_chain_id",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_chain_id"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_allowed_token_in",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_allowed_token_in"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_allowed_token_out",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_allowed_token_out"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_max_input_amount",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_max_input_amount"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_max_slippage_bps",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_max_slippage_bps"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_deadline_seconds",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_deadline_seconds"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_recipient",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_recipient"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_router",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_router"
              ]
            },
            {
              "purpose": "Visa text record agent_policy_uniswap_selector",
              "to": "{{nodes.ens_resolve_passport.outputs.resolverAddress}}",
              "function": "text(bytes32,string)",
              "params": [
                "{{input.agentNode}}",
                "agent_policy_uniswap_selector"
              ]
            }
          ]
        }
      }
    },
    {
      "id": "check_agent_exists",
      "type": "condition",
      "position": {
        "x": 640,
        "y": -180
      },
      "capabilityStatus": "template-not-live-import-proven",
      "data": {
        "label": "Passport exists?",
        "blockedCode": "MISSING_SIGNER",
        "description": "Requires nonzero resolver and addr(agent) from live ENS.",
        "config": {
          "trueLabel": "continue",
          "falseLabel": "emit blocked-stamp",
          "expression": "{{checks.check_agent_exists.passed}}"
        }
      }
    },
    {
      "id": "check_status_active",
      "type": "condition",
      "position": {
        "x": 960,
        "y": -180
      },
      "capabilityStatus": "template-not-live-import-proven",
      "data": {
        "label": "Visa status active?",
        "blockedCode": "STATUS_NOT_ACTIVE",
        "description": "Requires ENS text agent_status to be exactly active.",
        "config": {
          "trueLabel": "continue",
          "falseLabel": "emit blocked-stamp",
          "expression": "{{checks.check_status_active.passed}}"
        }
      }
    },
