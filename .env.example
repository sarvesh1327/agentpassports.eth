# AgentPassports.eth local environment template.
# Copy to .env and fill secrets locally. Never commit real keys, RPC URLs, or tokens.

# Public frontend configuration. These values are safe to expose in browser bundles.
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
NEXT_PUBLIC_NAME_WRAPPER=0x0635513f179D50A207757E05759CbD106d7dFcE8
NEXT_PUBLIC_PUBLIC_RESOLVER=0xE99638b40E4Fff0129D56f03b55b6bbC4BBE49b5
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_EXECUTOR_ADDRESS=0xce3e365214568E96d4186464089438a89331941F
NEXT_PUBLIC_TASK_LOG_ADDRESS=0x9f384B659da5F24994BC5c2a10B4243F07aA889b
NEXT_PUBLIC_TASK_LOG_START_BLOCK=10767184

# Optional public demo placeholders. Leave blank unless you intentionally want a prefilled local demo profile.
NEXT_PUBLIC_DEMO_OWNER_ENS=
NEXT_PUBLIC_DEMO_AGENT_LABEL=
NEXT_PUBLIC_DEMO_AGENT_ADDRESS=
NEXT_PUBLIC_DEMO_POLICY_URI=

# Server-only web/runtime values. Do not prefix secrets with NEXT_PUBLIC_.
AGENTPASSPORT_DB_PATH=
AGENT_DIRECTORY_DB_PATH=
PINATA_JWT=
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

# KeeperHub validates Passport/Visa state and executes the current workflow.
KEEPERHUB_API_KEY=
KEEPERHUB_API_BASE_URL=https://app.keeperhub.com
KEEPERHUB_WORKFLOW_ID=kah3xyaxk2uskluggff4q

# MCP / agent-runner / contract scripts.
CHAIN_ID=11155111
ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
EXECUTOR_ADDRESS=0xce3e365214568E96d4186464089438a89331941F
TASK_LOG_ADDRESS=0x9f384B659da5F24994BC5c2a10B4243F07aA889b
RPC_URL=
SEPOLIA_RPC_URL=
ETHERSCAN_API_KEY=

# Optional Uniswap quote/build API helpers. Runtime execution remains KeeperHub-authoritative.
UNISWAP_API_KEY=
UNISWAP_BASE_URL=https://trade-api.gateway.uniswap.org/v1
